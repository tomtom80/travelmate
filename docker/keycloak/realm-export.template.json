{
  "realm": "travelmate",
  "enabled": true,
  "displayName": "Travelmate",
  "loginTheme": "travelmate",
  "emailTheme": "travelmate",
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "none",
  "internationalizationEnabled": true,
  "supportedLocales": ["de", "en"],
  "defaultLocale": "de",
  "attributes": {
    "appBaseUrl": "${APP_BASE_URL}"
  },
  "rememberMe": true,
  "roles": {
    "realm": [
      {
        "name": "organizer",
        "description": "Can create and manage trips"
      },
      {
        "name": "participant",
        "description": "Can join trips and participate"
      }
    ]
  },
  "groups": [
    {
      "name": "organizers",
      "realmRoles": ["organizer"]
    },
    {
      "name": "participants",
      "realmRoles": ["participant"]
    }
  ],
  "clients": [
    {
      "clientId": "travelmate-gateway",
      "name": "Travelmate Gateway",
      "enabled": true,
      "baseUrl": "${APP_BASE_URL}/iam/",
      "publicClient": false,
      "secret": "travelmate-gateway-secret",
      "redirectUris": [
        "${APP_BASE_URL}/login/oauth2/code/keycloak",
        "${APP_BASE_URL}/*"
      ],
      "webOrigins": [
        "${APP_BASE_URL}"
      ],
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "basic",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "email": "testuser@travelmate.local",
      "credentials": [
        {
          "type": "password",
          "value": "testpassword",
          "temporary": false
        }
      ],
      "realmRoles": [
        "organizer",
        "participant"
      ]
    },
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@travelmate.local",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "organizer",
        "participant"
      ]
    }
  ],
  "scopeMappings": [],
  "clientScopeMappings": {},
  "requiredActions": [
    {
      "alias": "VERIFY_EMAIL",
      "name": "Verify Email",
      "providerId": "VERIFY_EMAIL",
      "enabled": true,
      "defaultAction": false,
      "priority": 50
    }
  ],
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "noreply@travelmate.local",
    "fromDisplayName": "Travelmate",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "identityProviders": [],
  "identityProviderMappers": []
}
