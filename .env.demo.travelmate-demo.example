# Travelmate demo environment for travelmate-demo.de
# Copy this file to /opt/travelmate-demo/.env.demo on the demo host.

# Public URLs
TRAVELMATE_PUBLIC_URL=https://travelmate-demo.de
KEYCLOAK_PUBLIC_URL=https://auth.travelmate-demo.de

# Container images
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=tomtom80
IMAGE_TAG=demo

# Keycloak
KEYCLOAK_ADMIN=travelmate-admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-strong-password
KEYCLOAK_CLIENT_SECRET=travelmate-gateway-secret
KEYCLOAK_DB_PASSWORD=replace-with-keycloak-db-password

# Shared application database password
DB_PASSWORD=replace-with-app-db-password

# RabbitMQ
RABBITMQ_USERNAME=travelmate
RABBITMQ_PASSWORD=replace-with-rabbitmq-password

# SMTP via STRATO
SMTP_HOST=smtp.strato.de
SMTP_PORT=587
SMTP_FROM=noreply@travelmate-demo.de
SMTP_FROM_DISPLAY_NAME=Travelmate Demo
MAIL_USERNAME=noreply@travelmate-demo.de
MAIL_PASSWORD=replace-with-strato-mailbox-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
SMTP_SSL=false
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000
