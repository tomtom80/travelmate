# Public URLs
TRAVELMATE_PUBLIC_URL=https://demo.travelmate.example
KEYCLOAK_PUBLIC_URL=https://auth.demo.travelmate.example

# Container images
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=your-github-user
IMAGE_TAG=demo

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_DB_PASSWORD=change-me

# Shared application database password
DB_PASSWORD=change-me

# RabbitMQ
RABBITMQ_USERNAME=travelmate
RABBITMQ_PASSWORD=change-me

# SMTP for application and Keycloak mails
# Recommended demo default: Brevo SMTP relay
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_FROM=noreply@travelmate.example
SMTP_FROM_DISPLAY_NAME=Travelmate-Demo
MAIL_USERNAME=your-brevo-smtp-login
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
SMTP_SSL=false
